@page
@model CourseWork.Pages.IndexModel
@{
    ViewData["Title"] = "Мапа транспорту";
}

<div class="mb-4">
    <h1 class="display-6 fw-bold text-dark"><i class="bi bi-geo-alt text-danger"></i> Доступний транспорт поруч</h1>
    <p class="text-muted">Знайдіть найближчий вільний самокат або велосипед на мапі.</p>
</div>

<!-- Map Container -->
<div id="map"></div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Черкаси center approx
            var map = L.map('map').setView([49.4445, 32.0621], 13);

            L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
                attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors &copy; <a href="https://carto.com/attributions">CARTO</a>',
                subdomains: 'abcd',
                maxZoom: 20
            }).addTo(map);

            // Custom icons
            var scooterIcon = L.divIcon({
                html: '<div style="background-color: #0d6efd; color: white; border-radius: 50%; width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 8px rgba(0,0,0,0.2); border: 2px solid white;"><i class="bi bi-scooter fs-5"></i></div>',
                className: '',
                iconSize: [36, 36],
                iconAnchor: [18, 18],
                popupAnchor: [0, -18]
            });

            var bikeIcon = L.divIcon({
                html: '<div style="background-color: #198754; color: white; border-radius: 50%; width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 8px rgba(0,0,0,0.2); border: 2px solid white;"><i class="bi bi-bicycle fs-5"></i></div>',
                className: '',
                iconSize: [36, 36],
                iconAnchor: [18, 18],
                popupAnchor: [0, -18]
            });

            var vehicles = @Html.Raw(Model.MapDataJson);
            var markers = [];

            vehicles.forEach(function (v) {
                var icon = v.category === 'Самокат' ? scooterIcon : bikeIcon;
                
                var batteryColor = v.battery > 50 ? 'text-success' : (v.battery > 20 ? 'text-warning' : 'text-danger');
                var batteryIcon = v.battery > 50 ? 'bi-battery-full' : (v.battery > 20 ? 'bi-battery-half' : 'bi-battery');

                var popupContent = `
                    <div class="popup-title">${v.name}</div>
                    <div class="popup-detail"><span class="badge bg-secondary mb-2">${v.category}</span></div>
                    <div class="popup-detail fw-bold ${batteryColor} mb-3"><i class="bi ${batteryIcon}"></i> Заряд: ${v.battery}%</div>
                    <form method="post" action="/Vehicles?handler=StartRental">
                        <!-- anti-forgery token needs to be here ideally, but since we are submitting to another page we might need it, or we just link -->
                    </form>
                    <a href="/Vehicles" class="btn btn-primary btn-sm w-100">Орендувати</a>
                `;

                var marker = L.marker([v.lat, v.lng], { icon: icon })
                    .addTo(map)
                    .bindPopup(popupContent);
                    
                markers.push(marker);
            });

            // Rental Points Icons
            var rpIcon = L.divIcon({
                html: '<div style="background-color: #6c757d; color: white; border-radius: 8px; width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 8px rgba(0,0,0,0.2); border: 2px solid white;"><i class="bi bi-p-square-fill fs-5"></i></div>',
                className: '',
                iconSize: [32, 32],
                iconAnchor: [16, 16],
                popupAnchor: [0, -16]
            });

            var rentalPoints = @Html.Raw(Model.RentalPointsJson);
            rentalPoints.forEach(function (rp) {
                var popupContent = `
                    <div class="popup-title">${rp.name}</div>
                    <div class="popup-detail text-muted mb-2"><i class="bi bi-geo-alt"></i> ${rp.address}</div>
                    <div class="popup-detail fw-bold text-secondary">Точка прокату (парковка)</div>
                `;

                var marker = L.marker([rp.lat, rp.lng], { icon: rpIcon })
                    .addTo(map)
                    .bindPopup(popupContent);
                    
                markers.push(marker);
            });

            // Adjust map view to fit all markers if any exist
            if (markers.length > 0) {
                var group = new L.featureGroup(markers);
                map.fitBounds(group.getBounds().pad(0.1));
            }
        });
    </script>
}
