@page
@model CourseWork.Pages.ActiveRentalsModel
@{
    ViewData["Title"] = "Активні оренди";
}

<h1 class="display-6 fw-bold mb-4"><i class="bi bi-clock-history text-warning"></i> Активні оренди</h1>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="alert alert-info alert-dismissible fade show shadow-sm" role="alert">
        @Model.Message
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-4">Клієнт</th>
                    <th>Транспорт</th>
                    <th>Час початку</th>
                    <th class="pe-4 text-end">Дія</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model.Rentals)
                {
                    <tr>
                        <td class="ps-4 fw-bold">@r.Client.LastName @r.Client.FirstName</td>
                        <td>
                            @if(r.Vehicle.VehicleType.Category == "Самокат") { <i class="bi bi-scooter text-primary me-1"></i> }
                            else { <i class="bi bi-bicycle text-success me-1"></i> }
                            @r.Vehicle.VehicleType.Name 
                            <span class="text-muted small">(@r.Vehicle.SerialNumber)</span>
                        </td>
                        <td><i class="bi bi-calendar-event me-1 text-muted"></i> @r.StartTime.ToString("g")</td>
                        <td class="pe-4 text-end">
                            <form method="post" asp-page-handler="EndRental" class="d-inline">
                                <input type="hidden" name="rentalId" value="@r.Id" />
                                <input type="hidden" name="endLatitude" value="49.4445" />
                                <input type="hidden" name="endLongitude" value="32.0621" />
                                <button type="submit" class="btn btn-sm btn-danger px-3 shadow-sm rounded-pill"><i class="bi bi-stop-circle"></i> Завершити</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
