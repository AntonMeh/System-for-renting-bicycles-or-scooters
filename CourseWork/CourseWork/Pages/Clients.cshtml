@page
@model CourseWork.Pages.ClientsModel
@{
    ViewData["Title"] = "Клієнти";
}

<h1 class="display-6 fw-bold mb-4"><i class="bi bi-people text-info"></i> Клієнти</h1>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-4">Прізвище</th>
                    <th>Ім'я</th>
                    <th>По батькові</th>
                    <th class="pe-4 text-end">Баланс</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model.Clients)
                {
                    <tr>
                        <td class="ps-4 fw-bold">@c.LastName</td>
                        <td>@c.FirstName</td>
                        <td>@c.Patronymic</td>
                        <td class="pe-4 text-end">
                            <span class="badge @(c.Balance > 100 ? "bg-success" : (c.Balance > 0 ? "bg-warning" : "bg-danger")) rounded-pill fs-6 px-3">
                                @c.Balance.ToString("F2") грн
                            </span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
